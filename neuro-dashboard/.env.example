# انسخ هذا الملف إلى .env (وليس .env.example) وضع معرّف Google الخاص بك
# Copy this file to .env and put your own Google OAuth Client ID below.
# See README.md -> "تفعيل مزامنة Google Drive" for step-by-step setup.

VITE_GOOGLE_CLIENT_ID=

# مفتاح خادم فقط (لا يُستخدم محليًا عبر Vite، يُضبط في Vercel Environment
# Variables مباشرة). يلزم فقط لميزة "الاستيراد من صورة الدفتر".
# See README.md -> "الاستيراد من صورة الدفتر".
ANTHROPIC_API_KEY=
